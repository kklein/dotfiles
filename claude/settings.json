{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "qc-claude-login",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_CONFIG_FILE": "/Users/kevin.klein/.claude/aws.config",
    "AWS_PROFILE": "qcaws",
    "AWS_REGION": "eu-central-1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-6-v1[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "eu.anthropic.claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "eu.anthropic.claude-haiku-4-5-20251001-v1:0"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "Bash(pixi lock)",
      "Bash(pixi install)",
      "Bash(pixi install *)",
      "mcp__ide__getDiagnostics"
    ]
  },
  "model": "eu.anthropic.claude-opus-4-6-v1[1m]",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "/tmp/claude",
        "~/Library/Caches",
        "~/.cache"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "pixi lock",
      "pixi install"
    ]
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  }
}
